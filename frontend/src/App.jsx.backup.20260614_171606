    htmlContent += '.stat-card.failed { background: #fee2e2; color: #991b1b; }\n';
    htmlContent += '.stat-card.time { background: #fef3c7; color: #92400e; }\n';
    htmlContent += '.stat-number { font-size: 36px; font-weight: bold; margin-bottom: 8px; }\n';
    htmlContent += '.stat-label { font-size: 13px; font-weight: 500; }\n';
    htmlContent += '.module-card { background: white; border-radius: 12px; margin-bottom: 24px; border: 1px solid #e2e8f0; }\n';
    htmlContent += '.module-header { padding: 16px 20px; background: #f8fafc; border-bottom: 2px solid #4f46e5; display: flex; justify-content: space-between; }\n';
    htmlContent += '.module-name { font-size: 16px; font-weight: bold; }\n';

    htmlContent += '.info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 20px; }\n';
    htmlContent += '.info-card { background: #f8fafc; padding: 16px 20px; border-radius: 12px; border-left: 4px solid #4f46e5; }\n';
    htmlContent += '.info-card label { font-size: 12px; color: #64748b; display: block; margin-bottom: 6px; text-transform: uppercase; font-weight: 600; }\n';
    htmlContent += '.info-card .value { font-size: 16px; font-weight: 600; color: #1e293b; }\n';

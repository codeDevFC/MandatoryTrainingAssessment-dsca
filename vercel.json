"DATABASE_URL": "postgresql://neondb_owner:npg_eFVCNZHu13iW@ep-lucky-butterfly-ann71upz-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require",
"JWT_SECRET": "careworks-super-secret-key-2025",
"PORT": "3002"
}
}

{
"version": 2,
"builds": [
{
"src": "frontend/package.json",
"use": "@vercel/static-build",
"config": {
"distDir": "dist",
"buildCommand": "npm install && npm run build"
}
},
{
"src": "backend/api/index.js",
"use": "@vercel/node"
}
],
"routes": [
{
"src": "/api/(.)",
"dest": "backend/api/index.js"
},
{
"src": "/(.)",
"dest": "frontend/$1",
"check": true
},
{
"src": "/(.*)",
"status": 200,
"dest": "frontend/index.html"
}
],
